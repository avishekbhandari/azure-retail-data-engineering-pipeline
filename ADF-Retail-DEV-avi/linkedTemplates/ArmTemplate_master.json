{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "ADF-Retail-DEV-avi"
		},
		"LS_ADLS_Retail_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://stretaildev001avishek.dfs.core.windows.net/"
		},
		"LS_AWS_S3_Retail_properties_typeProperties_accessKeyId": {
			"type": "object",
			"defaultValue": {
				"type": "AzureKeyVaultSecret",
				"store": {
					"referenceName": "LS_KeyVault_Retail",
					"type": "LinkedServiceReference"
				},
				"secretName": "aws-access-key"
			}
		},
		"LS_AzureSQL_Retail_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "sql-retail-dev-avi01.database.windows.net"
		},
		"LS_AzureSQL_Retail_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "RetailDW"
		},
		"LS_AzureSQL_Retail_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "admin01"
		},
		"LS_KeyVault_Retail_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://KV-Retail-Dev-avi.vault.azure.net/"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "ADF-Retail-DEV-avi_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"LS_ADLS_Retail_properties_typeProperties_url": {
						"value": "[parameters('LS_ADLS_Retail_properties_typeProperties_url')]"
					},
					"LS_KeyVault_Retail_properties_typeProperties_baseUrl": {
						"value": "[parameters('LS_KeyVault_Retail_properties_typeProperties_baseUrl')]"
					},
					"LS_AWS_S3_Retail_properties_typeProperties_accessKeyId": {
						"value": "[parameters('LS_AWS_S3_Retail_properties_typeProperties_accessKeyId')]"
					},
					"LS_AzureSQL_Retail_properties_typeProperties_server": {
						"value": "[parameters('LS_AzureSQL_Retail_properties_typeProperties_server')]"
					},
					"LS_AzureSQL_Retail_properties_typeProperties_database": {
						"value": "[parameters('LS_AzureSQL_Retail_properties_typeProperties_database')]"
					},
					"LS_AzureSQL_Retail_properties_typeProperties_userName": {
						"value": "[parameters('LS_AzureSQL_Retail_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}